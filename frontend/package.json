{
  "name": "memory-twin-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync:vad-assets": "node scripts/sync-vad-assets.mjs",
    "postinstall": "node scripts/sync-vad-assets.mjs",
    "prebuild": "node scripts/sync-vad-assets.mjs",
    "dev": "vite",
    "build": "vite build",
    "model:live": "node scripts/create-live-glb.mjs public/models/lacrimosa-optimized.glb public/models/lacrimosa-live.raw.glb && gltf-transform optimize public/models/lacrimosa-live.raw.glb public/models/lacrimosa-live.glb --compress meshopt --texture-compress webp --texture-size 512 --simplify false --join false --flatten false --palette false && node -e \"require('node:fs').rmSync('public/models/lacrimosa-live.raw.glb',{force:true})\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "@ricky0123/vad-web": "^0.0.30",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.1",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "meshoptimizer": "^1.2.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
