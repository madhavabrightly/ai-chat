# Memory Twin AI — Environment Configuration
# Copy this file to .env and fill in values.

# --- Model Settings ---
# LLM model name (from HuggingFace / ModelScope)
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Embedding model name
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B

# --- Paths ---
# Where to cache downloaded model weights (outside git repo)
MODEL_CACHE_DIR=/workspace/memory_twin_models

# Where ChromaDB persists its vector index (outside git repo)
CHROMA_DB_DIR=/workspace/memory_twin_chroma

# Where to store downloaded datasets
DATASETS_DIR=./datasets

# --- Performance ---
# Set to "true" to force CPU inference (useful when no GPU available)
FORCE_CPU=false
