# Memory Twin AI — Environment Configuration
# Copy this file to .env and fill in values.

# --- Model IDs ---
LLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL_ID=Qwen/Qwen3-Embedding-0.6B
TTS_MODEL_ID=iic/CosyVoice-300M
ASR_MODEL_ID=iic/SenseVoiceSmall
AVATAR_VIDEO_MODEL_ID=AI-ModelScope/MuseTalk
AVATAR_ACTION_MODEL_ID=Qwen/Qwen3-0.6B

# --- Paths ---
MODEL_ROOT=/workspace/memory_twin_models
RUNTIME_ROOT=/workspace/memory_twin_runtime
CHROMA_DB_DIR=/workspace/memory_twin_runtime/chroma_db
GENERATED_AUDIO_DIR=/workspace/memory_twin_runtime/generated_audio
GENERATED_AVATAR_DIR=/workspace/memory_twin_runtime/generated_avatar_clips

# --- Feature Toggles ---
ENABLE_MUSETALK=false
ENABLE_MODEL_TTS=true
ENABLE_MODEL_ASR=true
ENABLE_AVATAR_ACTION_MODEL=true
AVATAR_ACTION_TIMEOUT_SECONDS=2.5
AVATAR_ACTION_DEVICE=auto

# --- Performance ---
FORCE_CPU=false
MAX_NEW_TOKENS=384
TOP_K_MEMORIES=3
